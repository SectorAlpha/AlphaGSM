#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker/manager/compose.yml"
STATE_DIR="${ALPHAGSM_HOME:-$SCRIPT_DIR/.alphagsm-docker}"
STATE_DIR="$(mkdir -p "$STATE_DIR" && cd "$STATE_DIR" && pwd)"
CONFIG_PATH="$STATE_DIR/alphagsm.conf"
EXAMPLE_CONFIG="$SCRIPT_DIR/docker/manager/alphagsm.conf.example"

compose_cmd() {
    if docker compose version >/dev/null 2>&1; then
        docker compose "$@"
        return
    fi
    if command -v docker-compose >/dev/null 2>&1; then
        docker-compose "$@"
        return
    fi
    echo "Docker Compose is required. Install Docker Compose plugin or docker-compose." >&2
    exit 1
}

ensure_config() {
    mkdir -p "$STATE_DIR"
    if [[ -f "$CONFIG_PATH" ]]; then
        return
    fi

    sed "s|/srv/alphagsm|$STATE_DIR|g" "$EXAMPLE_CONFIG" > "$CONFIG_PATH"
    echo "Wrote $CONFIG_PATH"
}

manager_compose() {
    ALPHAGSM_HOME="$STATE_DIR" compose_cmd -f "$COMPOSE_FILE" "$@"
}

manager_running() {
    local services

    services="$(manager_compose ps --status running --services 2>/dev/null || true)"
    grep -qx 'alphagsm' <<<"$services"
}

ensure_manager() {
    ensure_config
    if manager_running; then
        return
    fi

    manager_compose up -d --build
}

exec_alphagsm() {
    ensure_manager
    manager_compose exec -T alphagsm python alphagsm "$@"
}

show_help() {
    cat <<EOF
Usage:
  ./alphagsm-docker up
  ./alphagsm-docker down
  ./alphagsm-docker shell
  ./alphagsm-docker logs
  ./alphagsm-docker compose <compose-args>
  ./alphagsm-docker <alphagsm-args>

Examples:
  ./alphagsm-docker up
  ./alphagsm-docker mymc create minecraft.vanilla
  ./alphagsm-docker mymc setup -n 25565 "$STATE_DIR/servers/mymc"
  ./alphagsm-docker mymc start

Notes:
  - Default state path: $STATE_DIR
  - Override with: ALPHAGSM_HOME=/absolute/path ./alphagsm-docker ...
  - Docker-backed server install paths must stay under ALPHAGSM_HOME so the
    host Docker daemon and the manager container see the same absolute path.
EOF
}

main() {
    local command="${1:-help}"

    case "$command" in
        help|-h|--help)
            show_help
            ;;
        up)
            shift
            ensure_config
            manager_compose up -d --build "$@"
            ;;
        down)
            shift
            manager_compose down "$@"
            ;;
        shell)
            shift
            ensure_manager
            manager_compose exec alphagsm bash "$@"
            ;;
        logs)
            shift
            ensure_config
            manager_compose logs -f alphagsm "$@"
            ;;
        compose)
            shift
            ensure_config
            manager_compose "$@"
            ;;
        *)
            exec_alphagsm "$@"
            ;;
    esac
}

main "$@"